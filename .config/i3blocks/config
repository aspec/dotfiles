full_text=
align=center
color=#FFFFFF
separator=false
separator_block_width=8

[Weather label]
full_text=
separator=false
color=#4088bf

[weather]
command=~/.i3/scripts/weather.sh "68502"
interval=60
separator=false

[separator]

[language_text]
full_text=
separator=false
color=#4088bf

[language]
command=xkblayout-state print %s | awk '{print toupper($0)}'
interval=1
signal=1

[separator]

[volume_text]
full_text=
separator=false
color=#4088bf

[volume]
command=/usr/share/i3blocks/volume
instance=Master
interval=1
signal=10

[separator]

[battery]
command=~/.i3/i3blocks-contrib/battery/battery
markup=pango
color=#4088bf
interval=30

[separator]

[date_text]
full_text=
color=#4088bf
separator=false

[date]
command=date '+%d-%m-%Y'
interval=360
separator=false

[separator]

[time_text]
full_text=
color=#4088bf

[time]
command=date '+%H:%M:%S' # | sed 's/:/h/'
interval=1
separator=false

[separator]
