Xft.antialias:              true
Xft.dpi:                    96
Xft.hinting:                true
Xft.hintstyle:              hintslight
Xft.rgba:                   rgb

! Switched from urxvt to termite terminal emulator

! URxvt.cursorBlink:          true
! URxvt.cursorColor:          #657b83
! URxvt.depth:                32
! URxvt.fading:               0
! URxvt.internalBorder:       3
! URxvt.imLocale:             en_US.UTF-8
! URxvt.iso14755:             false
! URxvt.iso14755_52:          false
! URxvt.geometry:             90x30
! URxvt.loginShell:           true
! URxvt.saveLines:            65536
! URxvt.scrollStyle:          rxvt
! URxvt.scrollBar:            false
! URxvt.pointerBlank:         true
! URxvt.transparent:          false
! URxvt.boldColors:           on
! URxvt.font:                 xft:Inconsolata for Powerline:pixelsize=15:medium
! URxvt.boldFont:             xft:Inconsolata for Powerline:pixelsize=15:bold

! Hybrid Terminal Colours. Uses the palette from Tomorrow-Night:
! https://github.com/chriskempson/tomorrow-theme/blob/master/vim/colors/Tomorrow-Night.vim
! vim: ft=xdefaults

*background: #1D1F21
*foreground: #C5C8C6
! black
*color0: #282A2E
*color8: #373B41
! red
*color1: #A54242
*color9: #CC6666
! green
*color2: #8C9440
*color10: #B5BD68
! yellow
*color3: #DE935F
*color11: #F0C674
! blue
*color4: #5F819D
*color12: #81A2BE
! magenta
*color5: #85678F
*color13: #B294BB
! cyan
*color6: #5E8D87
*color14: #8ABEB7
! white
*color7: #707880
*color15: #C5C8C6
